generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  DOCTOR
  NURSE
  STAFF
}

enum AuditAction {
  LOGIN_SUCCESS
  LOGIN_FAILURE
  PATIENT_CREATED
  PATIENT_UPDATED
  PATIENT_DELETED
  PATIENT_ANONYMIZED
  PATIENT_EXPORT
  NOTE_CREATED
  NOTE_UPDATED
  NOTE_DELETED
  USER_ROLE_CHANGED
}

enum AuditEntityType {
  USER
  PATIENT
  NOTE
  VOICE_NOTE
  REPORT
  AUTH
}

model Clinic {
  id           String        @id @default(uuid())
  name         String        @unique
  createdAt    DateTime      @default(now())
  users        User[]
  patients     Patient[]
  medicalNotes MedicalNote[]
  voiceNotes   VoiceNote[]
  reports      Report[]
  templates    Template[]
  featureFlags FeatureFlag[]
  subscription Subscription?
  retentionPolicy RetentionPolicy?
  onboardingProgress OnboardingProgress?
  invitations Invitation[]
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  CLINIC
}

model User {
  id         String        @id @default(uuid())
  name       String
  email      String        @unique
  password   String
  clinicName String
  clinicId   String
  role       UserRole      @default(DOCTOR)
  noteCount  Int           @default(0)
  createdAt  DateTime      @default(now())
  clinic     Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patients   Patient[]
  notes      MedicalNote[]
  voiceNotes VoiceNote[]
  reports    Report[]
  sentInvitations Invitation[]

  @@index([clinicId])
  @@index([clinicId, id])
}

model Patient {
  id         String        @id @default(uuid())
  fullName   String
  age        Int
  gender     String
  phone      String
  doctorId   String
  clinicId   String
  createdAt  DateTime      @default(now())
  deletedAt  DateTime?
  anonymizedAt DateTime?
  doctor     User          @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  clinic     Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  notes      MedicalNote[]
  voiceNotes VoiceNote[]
  reports    Report[]

  @@unique([clinicId, id])
  @@index([doctorId])
  @@index([clinicId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([anonymizedAt])
}

model MedicalNote {
  id               String   @id @default(uuid())
  rawInputText     String
  structuredOutput String
  doctorId         String
  patientId        String
  clinicId         String
  createdAt        DateTime @default(now())
  deletedAt        DateTime?
  doctor           User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient          Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic           Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, id])
  @@index([doctorId])
  @@index([patientId])
  @@index([clinicId])
  @@index([createdAt])
  @@index([deletedAt])
}

model VoiceNote {
  id              String   @id @default(uuid())
  clinicId        String
  patientId       String
  createdByUserId String
  audioKey        String
  transcript      String?
  durationSeconds Int
  fileSizeBytes   Int
  mimeType        String
  createdAt       DateTime @default(now())
  deletedAt       DateTime?
  createdByUser   User     @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  patient         Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic          Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, id])
  @@index([createdByUserId])
  @@index([patientId])
  @@index([clinicId])
  @@index([createdAt])
  @@index([deletedAt])
}

model Report {
  id        String   @id @default(uuid())
  title     String
  content   String
  doctorId  String
  patientId String
  clinicId  String
  createdAt DateTime @default(now())
  doctor    User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient   Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, id])
  @@index([doctorId])
  @@index([patientId])
  @@index([clinicId])
  @@index([createdAt])
}

model AuditLog {
  id         String          @id @default(uuid())
  clinicId   String
  userId     String
  action     AuditAction
  entityType AuditEntityType
  entityId   String?
  metadata   Json?
  ipAddress  String
  userAgent  String
  createdAt  DateTime        @default(now())

  @@index([clinicId])
  @@index([userId])
  @@index([createdAt])
}

model Template {
  id        String   @id @default(uuid())
  clinicId  String
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clinic    Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, id])
  @@index([clinicId])
  @@index([createdAt])
}

model RetentionPolicy {
  id                          String   @id @default(uuid())
  clinicId                    String   @unique
  patientRecordRetentionYears Int      @default(7)
  auditLogRetentionYears      Int      @default(7)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  clinic                      Clinic   @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, id])
  @@index([createdAt])
}

model Subscription {
  id                   String           @id @default(uuid())
  clinicId             String           @unique
  stripeCustomerId     String           @unique
  stripeSubscriptionId String?          @unique
  plan                 SubscriptionPlan
  status               String
  currentPeriodEnd     DateTime?
  clinic               Clinic           @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId, id])
  @@index([stripeSubscriptionId])
}

model FeatureFlag {
  id       String  @id @default(uuid())
  name     String
  enabled  Boolean @default(false)
  clinicId String?
  clinic   Clinic? @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([clinicId])
  @@unique([name, clinicId])
}

enum OnboardingStep {
  CLINIC_SETUP
  ADD_DOCTORS
  ADD_PATIENTS
  RECORD_NOTE
  COMPLETE
}

model OnboardingProgress {
  id          String        @id @default(uuid())
  clinicId    String
  currentStep OnboardingStep @default(CLINIC_SETUP)
  completedSteps String[]    @default([])
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  clinic      Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([clinicId])
  @@index([clinicId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

model Invitation {
  id           String          @id @default(uuid())
  email        String
  clinicId     String
  role         UserRole        @default(DOCTOR)
  status       InvitationStatus @default(PENDING)
  token        String          @unique @map("token")
  expiresAt    DateTime
  invitedById  String
  createdAt    DateTime        @default(now())
  acceptedAt   DateTime?
  clinic       Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  invitedBy    User            @relation(fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@index([email])
  @@map("Invitation")
}
